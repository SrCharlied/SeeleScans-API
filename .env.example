# Estos valores funcionan tal cual para correr LOCAL (docker-compose.yml dev).
# Para PROD cambiar DB_PASSWORD, JWT_SECRET, PUBLIC_BASE_URL y CORS_ORIGIN.

PORT=3000

# DB_HOST: 'db' cuando la API corre dentro de docker compose (nombre del service);
# 'localhost' si la API corre fuera de docker apuntando al puerto expuesto.
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
# ⚠️ Solo dev. En prod generar uno fuerte: openssl rand -base64 24
DB_PASSWORD=1234
DB_NAME=manga_db
# ⚠️ Solo dev. Reemplazar en prod.
JWT_SECRET=change_me

# URL pública con la que la API se devuelve a sí misma en respuestas (ej. URLs de uploads).
# Dev:  http://localhost:3000
# Prod: https://api.seele.servigtdev.com
PUBLIC_BASE_URL=http://localhost:3000

# Orígen permitido por CORS. '*' acepta cualquiera (OK para dev).
# En prod restringir al dominio del cliente, ej.: https://seelescans.servigtdev.com
CORS_ORIGIN=*
